---
import type { CollectionEntry, RenderResult } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.astro';
import TableOfContents from '../components/TableOfContents.astro';
interface Props { note: CollectionEntry<'notes'>; rendered: RenderResult; previous?: CollectionEntry<'notes'>; next?: CollectionEntry<'notes'>; }
const { note, rendered, previous, next } = Astro.props;
const { Content, headings } = rendered;
const formatted = note.data.date.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title={note.data.title} description={note.data.description} type="article">
  <article class="reading-width article">
    <a class="back" href="/notes/">← Back to Notes</a>
    <header class="article-head">
      <p class="eyebrow">{note.data.category}</p>
      <h1>{note.data.title}</h1>
      <p class="description">{note.data.description}</p>
      <div class="article-meta"><time datetime={note.data.date.toISOString()}>{formatted}</time><span>{note.data.status}</span></div>
      <TagList tags={note.data.tags} linked />
    </header>
    <TableOfContents headings={headings} />
    <div class="prose"><Content /></div>
    <footer class="note-footer"><p>This is a living note and may be revised as my understanding changes.</p><TagList tags={note.data.tags} linked /></footer>
    <nav class="note-nav" aria-label="Adjacent notes">
      <div>{previous && <><span>Previous</span><a href={`/notes/${previous.id}/`}>{previous.data.title}</a></>}</div>
      <div class="next">{next && <><span>Next</span><a href={`/notes/${next.id}/`}>{next.data.title}</a></>}</div>
    </nav>
  </article>
  <script>
    import mermaid from 'mermaid';
    document.querySelectorAll('.prose pre').forEach((pre) => {
      const button = document.createElement('button'); button.className = 'copy-code'; button.type = 'button'; button.textContent = 'Copy';
      button.addEventListener('click', async () => { await navigator.clipboard.writeText(pre.querySelector('code')?.textContent || ''); button.textContent = 'Copied'; setTimeout(() => button.textContent = 'Copy', 1500); });
      pre.append(button);
    });
    const mermaidBlocks = [...document.querySelectorAll('pre code.language-mermaid')];
    if (mermaidBlocks.length) {
      mermaidBlocks.forEach((code) => { const div = document.createElement('div'); div.className = 'mermaid'; div.textContent = code.textContent; code.parentElement?.replaceWith(div); });
      mermaid.initialize({ startOnLoad: true, theme: document.documentElement.dataset.theme === 'dark' || matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'neutral' });
    }
  </script>
</BaseLayout>
<style>
  .article { padding-top: clamp(3rem, 8vw, 6rem); }
  .back { color: var(--muted); font-size: .86rem; text-decoration: none; }
  .article-head { margin: 2.3rem 0 2rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
  .article-head h1 { margin: .25rem 0 .8rem; font-size: clamp(2.4rem, 7vw, 4.4rem); }
  .description { color: var(--muted); font-size: 1.1rem; }
  .article-meta { display: flex; gap: .8rem; margin: 1.2rem 0 .7rem; color: var(--faint); font-size: .8rem; text-transform: capitalize; }
  .article-meta span::before { content: '·'; margin-right: .8rem; }
  .note-footer { margin-top: 4rem; padding: 1.5rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); color: var(--muted); font-style: italic; }
  .note-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2rem; }
  .note-nav div { display: flex; align-items: start; flex-direction: column; }
  .note-nav .next { align-items: end; text-align: right; }
  .note-nav span { color: var(--faint); font-size: .74rem; letter-spacing: .08em; text-transform: uppercase; }
  .note-nav a { margin-top: .3rem; color: var(--text); font-family: var(--serif); font-size: 1.05rem; text-decoration: none; }
  @media (max-width: 560px) { .note-nav { grid-template-columns: 1fr; } .note-nav .next { align-items: start; text-align: left; } }
</style>
