---
import { SITE } from '../config/site';
---
<footer><div class="container footer-inner"><p>© {new Date().getFullYear()} Riley Luo. Built as a quiet place to think in public.</p><a href={SITE.github}>GitHub ↗</a></div></footer>
<style>
  footer { margin-top: 5rem; padding: 2.2rem 0; border-top: 1px solid var(--border); color: var(--muted); font-size: .86rem; }
  .footer-inner { display: flex; justify-content: space-between; gap: 1rem; }
  footer p { margin: 0; }
  @media (max-width: 600px) { .footer-inner { flex-direction: column; } }
</style>
