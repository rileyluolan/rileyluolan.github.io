---
import type { CollectionEntry } from 'astro:content';
import TagList from './TagList.astro';
interface Props { note: CollectionEntry<'notes'>; }
const { note } = Astro.props;
const date = note.data.date.toLocaleDateString('en', { year: 'numeric', month: 'short', day: '2-digit' });
---
<article class="note-card" data-note data-category={note.data.category} data-tags={note.data.tags.join('|').toLowerCase()} data-search={`${note.data.title} ${note.data.description} ${note.data.category} ${note.data.tags.join(' ')}`.toLowerCase()}>
  <div class="meta"><time datetime={note.data.date.toISOString()}>{date}</time><span>{note.data.category}</span><span class={`status ${note.data.status}`}>{note.data.status}</span></div>
  <h2><a href={`/notes/${note.id}/`}>{note.data.title}</a></h2>
  <p>{note.data.description}</p>
  <TagList tags={note.data.tags} />
</article>
<style>
  .note-card { padding: 1.7rem 0 2rem; border-top: 1px solid var(--border); }
  .meta { display: flex; flex-wrap: wrap; gap: .45rem .9rem; color: var(--faint); font-size: .78rem; }
  .meta span + span::before { content: '·'; margin-right: .9rem; }
  .status { color: var(--accent); }
  .note-card h2 { margin: .5rem 0 .45rem; font-size: clamp(1.4rem, 3vw, 1.8rem); }
  .note-card h2 a { color: var(--text); text-decoration: none; }
  .note-card h2 a:hover { color: var(--accent); }
  .note-card p { max-width: 670px; margin: 0 0 .8rem; color: var(--muted); }
</style>
