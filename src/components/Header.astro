---
import ThemeToggle from './ThemeToggle.astro';
import { SITE } from '../config/site';
const pathname = Astro.url.pathname;
const links = [['Home', '/'], ['Notes', '/notes'], ['Projects', '/projects'], ['Now', '/now'], ['About', '/about']] as const;
---
<header class="site-header">
  <div class="container bar">
    <a class="mark" href="/" aria-label="Riley Luo home">RL<span>·</span></a>
    <button class="menu-button" type="button" aria-expanded="false" aria-controls="site-nav"><span></span><span></span><span></span><span class="sr-only">Menu</span></button>
    <nav id="site-nav" aria-label="Primary navigation">
      {links.map(([label, href]) => <a href={href} aria-current={pathname === href || (href !== '/' && pathname.startsWith(href)) ? 'page' : undefined}>{label}</a>)}
      <a href={SITE.github} target="_blank" rel="noreferrer">GitHub <span aria-hidden="true">↗</span></a>
      <ThemeToggle />
    </nav>
  </div>
</header>
<script>
  const menu = document.querySelector<HTMLButtonElement>('.menu-button');
  const nav = document.querySelector<HTMLElement>('#site-nav');
  menu?.addEventListener('click', () => { const open = menu.getAttribute('aria-expanded') === 'true'; menu.setAttribute('aria-expanded', String(!open)); nav?.classList.toggle('open', !open); });
</script>
<style>
  .site-header { position: sticky; z-index: 50; top: 0; border-bottom: 1px solid color-mix(in srgb, var(--border) 75%, transparent); background: var(--header); backdrop-filter: blur(8px); }
  .bar { display: flex; min-height: 4.25rem; align-items: center; justify-content: space-between; }
  .mark { color: var(--text); font: 700 1.08rem/1 var(--serif); letter-spacing: .05em; text-decoration: none; }
  .mark span { color: var(--accent); }
  nav { display: flex; align-items: center; gap: 1.25rem; }
  nav a { color: var(--muted); font-size: .9rem; text-decoration: none; }
  nav a:hover, nav a[aria-current='page'] { color: var(--text); }
  nav a[aria-current='page'] { text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: .45rem; }
  .menu-button { display: none; border: 0; background: none; color: var(--text); }
  .menu-button span:not(.sr-only) { display: block; width: 1.35rem; height: 1px; margin: 5px; background: currentColor; }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }
  @media (max-width: 760px) {
    .menu-button { display: block; padding: .5rem; }
    nav { display: none; position: absolute; top: 4.25rem; left: 0; right: 0; align-items: stretch; flex-direction: column; gap: 0; padding: .75rem 1.25rem 1.25rem; border-bottom: 1px solid var(--border); background: var(--bg); }
    nav.open { display: flex; }
    nav a { padding: .65rem 0; }
    nav :global(.theme-toggle) { margin-top: .5rem; }
  }
</style>
